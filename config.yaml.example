# ReflectSonar Configuration File
# Values here override command line arguments

# SonarQube project key
project: your-project-key

# SonarQube user token
token: squ_your_user_token_here

# SonarQube server url 
url: http://localhost:9000

# Output PDF file path
output: reports/quality-report.pdf

# Enable verbose logging (bool)
verbose: false

# Skip fetching and rendering code snippets (bool)
no_snippets: false

# Only include BLOCKER or HIGH-severity issues and HIGH-probability hotspots (bool)
high_severity_only: false

# Skip fetching rule descriptions and omit the Rules Reference section (bool)
no_rules: false
